# Required for LLM calls (playground, scenario generation, replay, judge)
OPENAI_API_KEY=

# Required for magic link authentication emails (https://resend.com)
RESEND_API_KEY=

# Secret for JWT token signing (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# Set to an email address to enable /api/auth/dev-login bypass (no email needed)
# Leave empty in production
DEV_AUTH_EMAIL=dev@local.test

# Frontend URL for magic link redirect and CORS (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000
